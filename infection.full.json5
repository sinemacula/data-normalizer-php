{
    $schema: "./vendor/infection/infection/resources/schema.json",
    source: {
        directories: [
            "src"
        ],
        // Mirrors the phpunit.xml.dist coverage excludes: these trees hold no
        // executable code.
        excludes: [
            "Contracts",
            "Exceptions"
        ]
    },
    logs: {
        summary: "build/infection-full-summary.log",
        text: "build/infection-full.log"
    },
    phpUnit: {
        configDir: ".",
        customPath: "vendor/bin/phpunit"
    },
    timeout: 15,
    mutators: {
        "@default": true
    }
}
